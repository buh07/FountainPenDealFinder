APP_ENV=dev
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fountain_pen
AUTO_CREATE_TABLES=false
REDIS_URL=redis://localhost:6379/0
DEFAULT_TIMEZONE=Asia/Tokyo
MIN_PROFIT_JPY=10000
MIN_PROFIT_PCT=0.25
CONFIDENT_MIN=0.75
POTENTIAL_MIN=0.45
USE_FIXTURE_FALLBACK=true
INGESTION_RETRY_ATTEMPTS=3
INGESTION_RETRY_BACKOFF_SECONDS=1.0
INGESTION_PARSE_MIN_COMPLETENESS=0.55
INGESTION_PARSE_MIN_VALID_ROWS=1

YAHOO_AUCTIONS_ENABLED=true
YAHOO_AUCTIONS_BASE_URL=https://auctions.yahoo.co.jp
YAHOO_AUCTIONS_SEARCH_PATH=/search/search
YAHOO_AUCTIONS_KEYWORD=万年筆
YAHOO_AUCTIONS_MAX_RESULTS=60
YAHOO_AUCTIONS_TIMEOUT_SECONDS=20
YAHOO_AUCTIONS_VERIFY_SSL=true
YAHOO_AUCTIONS_REQUEST_INTERVAL_SECONDS=0

YAHOO_FLEA_MARKET_ENABLED=true
YAHOO_FLEA_MARKET_BASE_URL=https://paypayfleamarket.yahoo.co.jp
YAHOO_FLEA_MARKET_SEARCH_PATH=/search
YAHOO_FLEA_MARKET_KEYWORD=万年筆
YAHOO_FLEA_MARKET_MAX_RESULTS=60
YAHOO_FLEA_MARKET_TIMEOUT_SECONDS=20
YAHOO_FLEA_MARKET_VERIFY_SSL=true
YAHOO_FLEA_MARKET_REQUEST_INTERVAL_SECONDS=0

MERCARI_ENABLED=true
MERCARI_BASE_URL=https://jp.mercari.com
MERCARI_SEARCH_PATH=/search
MERCARI_KEYWORD=万年筆
MERCARI_MAX_RESULTS=60
MERCARI_TIMEOUT_SECONDS=20
MERCARI_VERIFY_SSL=true
MERCARI_REQUEST_INTERVAL_SECONDS=0

RAKUMA_ENABLED=true
RAKUMA_BASE_URL=https://fril.jp
RAKUMA_SEARCH_PATH=/s
RAKUMA_KEYWORD=万年筆
RAKUMA_MAX_RESULTS=60
RAKUMA_TIMEOUT_SECONDS=20
RAKUMA_VERIFY_SSL=true
RAKUMA_REQUEST_INTERVAL_SECONDS=0

WORKER_ENABLE_SCHEDULER=false
WORKER_FIXED_SOURCE_INTERVAL_SECONDS=3600
WORKER_ENDING_AUCTIONS_INTERVAL_SECONDS=900
WORKER_PRIORITY_INTERVAL_SECONDS=300
WORKER_IDLE_SLEEP_SECONDS=10
WORKER_ENDING_AUCTION_WINDOW_HOURS=24
WORKER_PRIORITY_WINDOW_HOURS=2
PRIORITY_SCORE_THRESHOLD=0.55
PRIORITY_VALUE_REFERENCE_JPY_CEILING=180000

RESALE_MODEL_ARTIFACT_PATH=models/resale/baseline_v1.json
AUCTION_MODEL_ARTIFACT_PATH=models/yahoo-auction/baseline_v1.json
MODEL_VERSION_ROOT=models/versions
MODEL_ACTIVE_POINTER_RESALE=models/resale/active_pointer.txt
MODEL_ACTIVE_POINTER_AUCTION=models/yahoo-auction/active_pointer.txt
BASELINE_EVAL_REPORT_PATH=models/eval/baseline_eval_v1.json
BASELINE_EVAL_MIN_ROWS=5
BASELINE_EVAL_RESALE_MAX_MAPE=0.5
BASELINE_EVAL_AUCTION_MAX_MAPE=0.4
BASELINE_EVAL_REQUIRE_HOLDOUT=true
BASELINE_EVAL_BOOTSTRAP_SAMPLES=1000
BASELINE_EVAL_SIGNIFICANCE_ALPHA=0.05
MONITORING_MIN_SOURCE_COUNT=1
MONITORING_MIN_PARSE_COMPLETENESS=0.65
MONITORING_MIN_NON_DISCARD_RATE=0.1
MONITORING_MAX_FALSE_POSITIVE_RATE=0.6
MONITORING_ALERT_WEBHOOK_URL=
MONITORING_ALERT_WEBHOOK_TIMEOUT_SECONDS=10
MONITORING_ALERT_DEDUPE_WINDOW_SECONDS=3600
MONITORING_ALERT_RETRY_ATTEMPTS=3
MONITORING_ALERT_RETRY_BACKOFF_SECONDS=1.0
MONITORING_MAX_MODEL_AGE_HOURS=720
MONITORING_MAX_LISTING_STALENESS_HOURS=12
WORKER_DISPATCH_HEALTH_ALERTS=false
WORKER_HEALTH_ALERT_WINDOW_HOURS=24

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With

FIXTURE_LISTINGS_PATH=data/fixtures/listings_sample.json
TAXONOMY_SEED_PATH=data/taxonomy/taxonomy_v1_seed.csv
TAXONOMY_FEEDBACK_TYPES_PATH=data/taxonomy/taxonomy_feedback_types.jsonl
FEEDBACK_PRICING_LABELS_PATH=data/labeled/raw/pen_swap_sales_feedback.jsonl
REPORTS_DIR=data/reports
OBJECT_STORE_ROOT=data/object_store
OBJECT_STORE_ENABLE_CAPTURE=false
OBJECT_STORE_CAPTURE_POLICY=scored_or_ending_soon
OBJECT_STORE_GENERATE_THUMBNAILS=false
OBJECT_STORE_THUMBNAIL_MAX_PX=320
IMAGE_CLASSIFIER_ENABLED=false
IMAGE_EMBEDDING_MODEL_NAME=local-hash-v1
IMAGE_CLASSIFIER_BLEND_MIN_CONFIDENCE=0.6
CLASSIFICATION_CALIBRATION_MIN_ROWS=30
CLASSIFICATION_CALIBRATION_BIN_COUNT=10
PROXY_COUPON_MAX_EXACT_STACKABLE=16
PROXY_COUPON_FALLBACK_TOP_STACKABLE=12
PROXY_FIRST_TIME_USER_PENALTY_JPY=350
RESALE_BRAND_MIN_SAMPLES=3
